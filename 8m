import java.security.*; 
import javax.crypto.*; 
import javax.crypto.spec.SecretKeySpec; 

public class AES { 

    // Convert byte array to Hex string 
    public static String asHex(byte[] buf) { 
        StringBuffer strbuf = new StringBuffer(buf.length * 2); 
        for (int i = 0; i < buf.length; i++) { 
            if (((int) buf[i] & 0xff) < 0x10) 
                strbuf.append("0"); 
            strbuf.append(Integer.toString((int) buf[i] & 0xff, 16)); 
        } 
        return strbuf.toString(); 
    } 

    public static void main(String[] args) throws Exception { 

        String message = "AES still rocks!!"; 

        // Get the KeyGenerator 
        KeyGenerator kgen = KeyGenerator.getInstance("AES"); 
        kgen.init(128);   // AES key size 

        // Generate secret key 
        SecretKey skey = kgen.generateKey(); 
        byte[ ] raw = skey.getEncoded(); 
        SecretKeySpec skeySpec = new SecretKeySpec(raw, "AES"); 

        // Instantiate the cipher (Encryption) 
        Cipher cipher = Cipher.getInstance("AES"); 
        cipher.init(Cipher.ENCRYPT_MODE, skeySpec); 

        byte[] encrypted = cipher.doFinal( 
                (args.length == 0 ? message : args[0]).getBytes()); 

        System.out.println("Encrypted string (Hex): " + asHex(encrypted)); 

        // Decryption 
        cipher.init(Cipher.DECRYPT_MODE, skeySpec); 
        byte[] original = cipher.doFinal(encrypted); 
        String originalString = new String(original); 

        System.out.println("Original string: " + originalString); 
        System.out.println("Original Hex   : " + asHex(original)); 
    } 
}
